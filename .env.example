# Supported values: asterisk, grandstream, freeswitch, yeastar, cucm, mock.
# Grandstream UCM aliases include grandstream-ucm and ucm6300.
# GUI aliases are accepted too: freepbx, issabel, vitalpbx, fusionpbx.
PBXSENSE_PBX_TYPE=asterisk
PBXSENSE_AGENT_MODE=ami
PBXSENSE_DISPLAY_NAME=Asterisk
PBXSENSE_TIMEZONE=Europe/Athens
PBXSENSE_AGENT_TOKEN=
PBXSENSE_CONNECT_TIMEOUT=3
PBXSENSE_SNAPSHOT_POLL_SECONDS=1
PBXSENSE_HISTORY_POLL_SECONDS=30
PBXSENSE_ENDPOINT_ACTIVITY_PATH=/var/lib/pbxsense-agent/endpoint_activity.json
# A phone must remain continuously unavailable/available for these periods
# before PBXSense alerts or announces its recovery.
PBXSENSE_ENDPOINT_OUTAGE_CONFIRMATION_SECONDS=5
PBXSENSE_ENDPOINT_RECOVERY_CONFIRMATION_SECONDS=5
PBXSENSE_TRUNK_OUTAGE_CONFIRMATION_SECONDS=5
# Individual unavailable-phone Health Signals use the confirmation above. The
# aggregate multi-phone Tip appears after this many continuous seconds (3m).
PBXSENSE_QUALITY_FREQUENCY_SECONDS=180

# PBXSense Cloud Run push relay. The protected Agent-page QR enrolls this
# installation and its paired phones; no manual claim code is needed.
PBXSENSE_RELAY_URL=https://pbxsense-push-relay-299065188499.europe-west1.run.app
# Keeps the encrypted relay capability ready. No PBX snapshot is uploaded
# until an app explicitly enables Internet Relay during pairing.
PBXSENSE_INTERNET_RELAY_ENABLED=true
PBXSENSE_INTERNET_RELAY_POLL_SECONDS=15
PBXSENSE_RELAY_IDENTITY_PATH=/var/lib/pbxsense-agent/relay_identity.json
PBXSENSE_RELAY_TIMEOUT=5
# Only required when the hosted relay enables paid/ticketed new enrollment.
# Existing enrolled Agents authenticate future pairing activations with their
# durable signing identity and do not need another ticket.
PBXSENSE_RELAY_ENROLLMENT_TICKET=

# HTTP port used by both the Linux service and Docker container.
PBXSENSE_AGENT_PORT=8765

# When running Docker Compose on the PBX host, 127.0.0.1 reaches local AMI
# because docker/docker-compose.yml uses network_mode: host.
ASTERISK_AMI_HOST=127.0.0.1
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USERNAME=pbxsense
ASTERISK_AMI_PASSWORD=change-me-before-running

# Grandstream UCM / SoftwareUCM AMI connector. Default plain AMI port is 7777.
# Set GRANDSTREAM_UCM_AMI_TLS=true to use TLS (default UCM TLS port: 5039).
GRANDSTREAM_UCM_AMI_HOST=127.0.0.1
GRANDSTREAM_UCM_AMI_PORT=7777
GRANDSTREAM_UCM_AMI_USERNAME=pbxsense
GRANDSTREAM_UCM_AMI_PASSWORD=change-me-before-running
GRANDSTREAM_UCM_AMI_TLS=false
GRANDSTREAM_UCM_AMI_VERIFY_TLS=true
# Optional local UCM files visible to a native Agent. The Grandstream Docker
# override supplies container paths automatically.
GRANDSTREAM_UCM_CDR_CSV_PATH=
GRANDSTREAM_UCM_VOICEMAIL_PATH=
GRANDSTREAM_UCM_RECORDINGS_PATH=
GRANDSTREAM_UCM_SECURITY_LOG_PATH=
# Docker host root: cdr/Master.csv, voicemail/, recordings/, security/.
GRANDSTREAM_UCM_FILES_HOST_PATH=../grandstream

# FreeSWITCH Event Socket connector. Used when PBXSENSE_PBX_TYPE=freeswitch.
FREESWITCH_ESL_HOST=127.0.0.1
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=
FREESWITCH_CDR_JSON_PATH=
FREESWITCH_VOICEMAIL_PATH=
FREESWITCH_RECORDINGS_PATH=
# Docker host root: cdr/, voicemail/, recordings/.
FREESWITCH_FILES_HOST_PATH=../freeswitch

# Yeastar P-Series API connector. Used when PBXSENSE_PBX_TYPE=yeastar.
# The base URL is the local PBX URL or the Yeastar Cloud FQDN, without /openapi.
YEASTAR_BASE_URL=
YEASTAR_CLIENT_ID=
YEASTAR_CLIENT_SECRET=
YEASTAR_API_VERSION=v1.0
# Set false only for a local PBX using a self-signed TLS certificate.
YEASTAR_VERIFY_TLS=true

# Cisco Unified Communications Manager. Use a dedicated read-only AXL and
# Standard CCM Server Monitoring application user.
CUCM_HOST=
CUCM_USERNAME=
CUCM_PASSWORD=
CUCM_AXL_VERSION=15.0
CUCM_VERIFY_TLS=true
CUCM_CDR_PATH=/var/lib/pbxsense-agent/cucm/cdr
CUCM_CMR_PATH=/var/lib/pbxsense-agent/cucm/cmr
CUCM_HISTORY_HOST_PATH=../cucm-history
# Optional live calls. Copy the Cisco JTAPI Client jars obtained from this
# CUCM cluster into vendor/jtapi in the repository when using Docker.
CUCM_JTAPI_HOST_PATH=../vendor/jtapi
CUCM_JTAPI_ENABLED=false
CUCM_JTAPI_CLASSPATH=/opt/pbxsense-agent/vendor/jtapi/*
CUCM_JTAPI_JAVA=java
CUCM_JTAPI_USERNAME=
CUCM_JTAPI_PASSWORD=
CUCM_JTAPI_POLL_SECONDS=1
CUCM_JTAPI_STALE_SECONDS=10
CUCM_JTAPI_RESTART_SECONDS=15

# Inside the PBXSense Agent container.
# Official Asterisk defaults:
#   CDR CSV:   /var/log/asterisk/cdr-csv/Master.csv
#   Voicemail: /var/spool/asterisk/voicemail
ASTERISK_CDR_CSV_PATH=/var/log/asterisk/cdr-csv/Master.csv
ASTERISK_VOICEMAIL_PATH=/var/spool/asterisk/voicemail
ASTERISK_RECORDINGS_PATH=/var/spool/asterisk/monitor
ASTERISK_SECURITY_LOG_PATH=/var/log/asterisk/security

# On the Docker host, relative to docker/docker-compose.asterisk.yml.
# For your Asterisk service:
#   ./asterisk/logs  -> /var/log/asterisk
#   ./asterisk/spool -> /var/spool/asterisk
#
# If PBXSense Agent lives beside the asterisk folder, keep these defaults.
# If the Agent repository is in the same folder as the asterisk folder,
# change them to ./asterisk/logs and ./asterisk/spool.
ASTERISK_LOGS_HOST_PATH=../../asterisk/logs
ASTERISK_SPOOL_HOST_PATH=../../asterisk/spool

# Optional friendly-name overrides. Leave empty for normal AMI endpoint labels.
# Use values like 101=Reception,120=Support only if your PBX exposes numbers
# without friendly names, or when you want nicer names in the app.
PBXSENSE_EXTENSION_NAMES=
